# ---- AI providers ----
ANTHROPIC_API_KEY=          # Claude — answer generation
OPENAI_API_KEY=             # embeddings (text-embedding-3-small)
GROQ_API_KEY=               # Whisper transcription (Phase 2)

# ---- Supabase (Frankfurt / eu-central) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=        # used to verify access tokens (Settings > API > JWT secret)
DATABASE_URL=               # postgres connection string (pgvector enabled); use a NON-bypass role for the app
DB_APP_ROLE=authenticated   # role assumed inside tenant txns so RLS is enforced (blank = no switch)
JWT_AUDIENCE=authenticated

# ---- Storage (audio, Phase 2) ----
S3_ENDPOINT=                # Cloudflare R2 or AWS S3 eu-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Connectors (CRM) ----
HUBSPOT_ACCESS_TOKEN=          # HubSpot Private App token (CRM sync)
HUBSPOT_SYNC_ORG_ID=           # daily cron sync target org (blank = cron skipped)
HUBSPOT_SYNC_OWNER_USER_ID=    # owner (org admin) for imported records

# ---- Cache / queue ----
REDIS_URL=

# ---- App ----
APP_ENV=development
JWT_SECRET=
